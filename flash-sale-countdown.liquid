{% comment %}
  Countdown Flash Sale ⚡
  Place this file in snippets/countdown-flash-sale.liquid
  Usage: {% render 'countdown-flash-sale' %}
  This countdown always shows 3 days remaining and refreshes daily.
{% endcomment %}

<div
  id="flash-sale-countdown"
  class="flash-sale-countdown"
  role="region"
  aria-live="polite"
  aria-label="Flash Sale countdown"
>
  <div class="flash-sale-inner">
    <span class="flash-sale-badge">Flash Sale ⚡</span>
    <div class="flash-sale-text">
      <strong class="flash-sale-title">Ends in</strong>
      <div class="countdown-timer" aria-hidden="false">
        <span class="countdown-part">
          <span class="countdown-value" id="ds">0</span><small>days</small>
        </span>
        <span class="countdown-sep">:</span>
        <span class="countdown-part">
          <span class="countdown-value" id="hs">00</span><small>hrs</small>
        </span>
        <span class="countdown-sep">:</span>
        <span class="countdown-part">
          <span class="countdown-value" id="ms">00</span><small>min</small>
        </span>
        <span class="countdown-sep">:</span>
        <span class="countdown-part">
          <span class="countdown-value" id="ss">00</span><small>sec</small>
        </span>
      </div>
    </div>
  </div>

  <div class="flash-sale-ended visually-hidden" id="flash-sale-ended">
    <strong>Flash Sale ended</strong>
  </div>
</div>

<style>
  :root {
    --fs-bg: #fff4e6;
    --fs-card: #ffffff;
    --fs-accent: #ff8a00;
    --fs-accent-2: #ffb347;
    --fs-text: #ff6a00;
    --fs-subtle: #a15b00;
    --fs-shadow: 0 10px 30px rgba(255, 138, 0, 0.25);
    --fs-radius: 16px;
  }

  .flash-sale-countdown {
    background: linear-gradient(135deg, #fff7ed 0%, #ffe7c6 100%);
    color: var(--fs-text);
    padding: 14px 16px;
    border-radius: var(--fs-radius);
    display: inline-block;
    font-family: "Inter", "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    box-shadow: var(--fs-shadow);
    border: 1px solid rgba(255, 138, 0, 0.25);
    position: relative;
    overflow: hidden;
  }

  .flash-sale-countdown::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(600px at 15% 30%, rgba(255, 174, 94, 0.35), transparent 50%),
      radial-gradient(480px at 80% 10%, rgba(255, 214, 153, 0.4), transparent 45%);
    pointer-events: none;
  }

  .flash-sale-inner {
    display: flex;
    align-items: center;
    gap: 14px;
    position: relative;
    z-index: 1;
  }

  .flash-sale-badge {
    background: linear-gradient(135deg, var(--fs-accent) 0%, var(--fs-accent-2) 100%);
    color: #5c2b00;
    padding: 8px 12px;
    border-radius: 999px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 13px;
    box-shadow: 0 6px 16px rgba(255, 138, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.6);
  }

  .flash-sale-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .flash-sale-title {
    display: block;
    font-size: 14px;
    color: var(--fs-subtle);
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .countdown-timer {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 16px;
    color: #ff5c00;
  }

  .countdown-part {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 58px;
    padding: 9px 11px;
    background: var(--fs-card);
    border-radius: 12px;
    border: 1px solid rgba(255, 138, 0, 0.2);
    box-shadow: 0 8px 20px rgba(255, 138, 0, 0.12);
  }

  .countdown-value {
    font-size: 20px;
    font-variant-numeric: tabular-nums;
    color: #d75a00;
  }

  .countdown-part small {
    margin-top: 2px;
    font-size: 11px;
    color: var(--fs-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .countdown-sep {
    opacity: 0.45;
    font-weight: 800;
    font-size: 18px;
    transform: translateY(-2px);
    color: #ff8a00;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .flash-sale-countdown.flash-sale-expired .flash-sale-inner {
    opacity: 0.4;
  }

  @media (max-width: 640px) {
    .flash-sale-countdown {
      width: 100%;
    }
    .flash-sale-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .countdown-timer {
      gap: 6px;
      flex-wrap: wrap;
    }
    .countdown-part {
      min-width: 70px;
      flex: 1 1 auto;
    }
  }
</style>

<script>
(function(){
  var container = document.getElementById('flash-sale-countdown');
  if (!container) return;

  var dEl = document.getElementById('ds');
  var hEl = document.getElementById('hs');
  var mEl = document.getElementById('ms');
  var sEl = document.getElementById('ss');
  var endedEl = document.getElementById('flash-sale-ended');

  // Timezone offset for +07:00 (UTC+7)
  var TZ_OFFSET_MS = 7 * 60 * 60 * 1000;

  function pad(n){ return String(n).padStart(2,'0'); }

  // Get current date in the target timezone (UTC+7)
  function getNowInTZ() {
    var now = new Date();
    var utc = now.getTime() + (now.getTimezoneOffset() * 60 * 1000);
    return new Date(utc + TZ_OFFSET_MS);
  }

  // Get start of day in target timezone
  function getStartOfDayInTZ(date) {
    var d = new Date(date);
    d.setHours(0, 0, 0, 0);
    return d;
  }

  // Calculate end date: 3 days from start of current day, at 23:59:59
  function calculateEndDate() {
    var now = getNowInTZ();
    var startOfToday = getStartOfDayInTZ(now);
    
    // Add 3 days
    var endDate = new Date(startOfToday);
    endDate.setDate(endDate.getDate() + 3);
    endDate.setHours(23, 59, 59, 999);
    
    return endDate;
  }

  // Get day key for tracking day changes (YYYY-MM-DD in target timezone)
  function getDayKey() {
    var now = getNowInTZ();
    var year = now.getFullYear();
    var month = String(now.getMonth() + 1).padStart(2, '0');
    var day = String(now.getDate()).padStart(2, '0');
    return year + '-' + month + '-' + day;
  }

  // Check if we need to refresh (new day detected)
  function checkDayChange() {
    var currentDayKey = getDayKey();
    var storedDayKey = localStorage.getItem('flash-sale-day-key');
    
    if (storedDayKey && storedDayKey !== currentDayKey) {
      // New day detected - refresh the page to recalculate
      localStorage.setItem('flash-sale-day-key', currentDayKey);
      window.location.reload();
      return true;
    }
    
    if (!storedDayKey) {
      localStorage.setItem('flash-sale-day-key', currentDayKey);
    }
    
    return false;
  }

  // Calculate time until next midnight in target timezone (for auto-refresh)
  function getMsUntilMidnight() {
    var now = getNowInTZ();
    var tomorrow = new Date(now);
    tomorrow.setDate(tomorrow.getDate() + 1);
    tomorrow = getStartOfDayInTZ(tomorrow);
    return tomorrow - now;
  }

  var endDate = calculateEndDate();

  function update(){
    // Check for day change
    if (checkDayChange()) {
      return; // Page will reload
    }

    var now = getNowInTZ();
    var diff = endDate - now;

    if (diff <= 0) {
      // Countdown reached zero - recalculate for next 3-day period
      endDate = calculateEndDate();
      diff = endDate - now;
    }

    var seconds = Math.floor(diff / 1000);
    var days = Math.floor(seconds / (24*3600));
    seconds -= days * 24*3600;
    var hours = Math.floor(seconds / 3600);
    seconds -= hours * 3600;
    var minutes = Math.floor(seconds / 60);
    var secs = seconds - minutes * 60;

    dEl.textContent = String(days);
    hEl.textContent = pad(hours);
    mEl.textContent = pad(minutes);
    sEl.textContent = pad(secs);

    // Hide ended message if countdown is active
    if (diff > 0) {
      endedEl.classList.add('visually-hidden');
      container.classList.remove('flash-sale-expired');
    } else {
      endedEl.classList.remove('visually-hidden');
      container.classList.add('flash-sale-expired');
    }
  }

  update();
  var timer = setInterval(update, 1000);

  // Schedule refresh at midnight (in target timezone)
  var msUntilMidnight = getMsUntilMidnight();
  setTimeout(function() {
    // Refresh page at midnight to recalculate
    window.location.reload();
  }, msUntilMidnight);
})();
</script>